# ─── Consumer ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Redis connection URL (from Railway Redis, Upstash, Redis Cloud, etc.)
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# Must match an existing Region.id in the database (run the seed script first)
REGION_ID="us-east-1"
