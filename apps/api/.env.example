# ─── API ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (from Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret for signing JWTs — generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-strong-random-secret"

# URL of your deployed frontend (for CORS). Use * for development only.
FRONTEND_URL="https://your-pingnova-app.vercel.app"

# Port the API listens on (Railway/Render set this automatically)
PORT=3000
