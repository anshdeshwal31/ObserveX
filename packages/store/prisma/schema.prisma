// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Website {
  id                     String        @id @default(uuid())
  url                    String
  user_id                String
  time_added             DateTime      @default(now())
  incident_open_after    Int?
  incident_resolve_after Int?
  ticks                  WebsiteTick[]
  incidents              Incident[]
  user                   User          @relation(fields: [user_id], references: [id])
}

model User {
  id       String    @id
  username String?   @unique
  email    String?   @unique
  websites Website[]
}

model Region {
  id    String        @id @default(uuid())
  name  String
  ticks WebsiteTick[]
}

model WebsiteTick {
  id               String        @id @default(uuid())
  response_time_ms Int
  status           WebsiteStatus
  region           Region        @relation(fields: [region_id], references: [id])
  website          Website       @relation(fields: [website_id], references: [id])
  region_id        String
  website_id       String
  created_at       DateTime      @default(now())
}

model Incident {
  id              String           @id @default(uuid())
  website_id      String
  status          IncidentStatus
  severity        IncidentSeverity
  title           String
  fingerprint     String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  acknowledged_at DateTime?
  resolved_at     DateTime?
  last_seen_at    DateTime?
  website         Website          @relation(fields: [website_id], references: [id])
  events          IncidentEvent[]
}

model IncidentEvent {
  id          String            @id @default(uuid())
  incident_id String
  type        IncidentEventType
  message     String?
  metadata    Json?
  created_at  DateTime          @default(now())
  incident    Incident          @relation(fields: [incident_id], references: [id])
}

enum WebsiteStatus {
  Up
  Down
  Unknown
}

enum IncidentStatus {
  Open
  Acknowledged
  Resolved
}

enum IncidentSeverity {
  Info
  Warning
  Critical
}

enum IncidentEventType {
  Detected
  Acknowledged
  Resolved
}
